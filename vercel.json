{
  "version": 2,
  "builds": [
    {
      "src": "frontend/api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "frontend/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/frontend/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/api/index.py"
    }
  ]
}
